# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# PostgreSQL  (OBLIGATORIO)
# La sesión de WhatsApp (Baileys) se persiste en la tabla `whatsapp_auth`,
# por eso el bot reconecta sin re-escanear el QR tras un reinicio o deploy.
# Sirve cualquier Postgres: local, Neon, Supabase o Render Postgres.
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:password@localhost:5432/whatsapp_bot

# ─────────────────────────────────────────────
# Google Sheets (vía Apps Script publicado como Web App)  (OBLIGATORIO)
# Pega aquí la URL /exec que te da Apps Script al desplegar.
# ─────────────────────────────────────────────
SHEETS_API_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# ─────────────────────────────────────────────
# IA (Groq) — https://console.groq.com/keys  (OBLIGATORIO)
# ─────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────
# Contraseña del panel de administración  (RECOMENDADO)
# Protege /qr y /reset con Basic Auth. Sin ella, esas rutas quedan bloqueadas (fail-closed).
# El usuario puede ser cualquiera; la contraseña es este valor.
# ─────────────────────────────────────────────
ADMIN_TOKEN=elige-una-contraseña-fuerte

# ─────────────────────────────────────────────
# Identidad del negocio (se muestra en el panel y los mensajes)
# ─────────────────────────────────────────────
BOT_COMPANY="Indias Motos"
BOT_SALES_REP="Asistente"
